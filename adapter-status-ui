    code, output = run(
        ["adb", "-s", adb_target(config), "pull", normalize_remote_path(remote_path), destination],
        timeout=120,
        purpose="file-pull",
    )
    if code == 0:
        output = (output + "\n" if output else "") + f"Đã lưu: {destination}"
    return code, output, destination


