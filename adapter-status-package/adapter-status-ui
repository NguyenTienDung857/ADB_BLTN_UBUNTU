        for css_class in ("terminal-ready", "terminal-wait"):
            ctx.remove_class(css_class)
        ctx.add_class("terminal-ready" if ready else "terminal-wait")


if __name__ == "__main__":
    app = AdapterStatus()
    app.connect("destroy", Gtk.main_quit)
    app.show_all()
    Gtk.main()
